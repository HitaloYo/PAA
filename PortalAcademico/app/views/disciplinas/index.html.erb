<section class="disciplinas-section">
  <h2><i class="bi bi-journal-bookmark"></i> Minhas Disciplinas</h2>
  <p class="descricao">
    Abaixo estão listadas suas disciplinas do período atual.
  </p>

  <div class="disciplinas-grid">
    <div class="disciplina-card">
      <i class="bi bi-code-slash"></i>
      <h3>Programação I</h3>
      <p><strong>Professor:</strong> Ana Costa</p>
      <p>Introdução à lógica de programação e desenvolvimento em Python.</p>
      <%= link_to "Acessar", "#", class: "disciplina-button" %>
    </div>

    <div class="disciplina-card">
      <i class="bi bi-cpu"></i>
      <h3>Arquitetura de Computadores</h3>
      <p><strong>Professor:</strong> Carlos Mendes</p>
      <p>Estudo dos componentes e funcionamento interno do computador.</p>
      <%= link_to "Acessar", "#", class: "disciplina-button" %>
    </div>

    <div class="disciplina-card">
      <i class="bi bi-diagram-3"></i>
      <h3>Estruturas de Dados</h3>
      <p><strong>Professor:</strong> Marina Oliveira</p>
      <p>Conceitos e implementação de listas, pilhas, filas e árvores.</p>
      <%= link_to "Acessar", "#", class: "disciplina-button" %>
    </div>

    <div class="disciplina-card">
      <i class="bi bi-graph-up"></i>
      <h3>Matemática Discreta</h3>
      <p><strong>Professor:</strong> João Silva</p>
      <p>Fundamentos matemáticos aplicados à computação e lógica formal.</p>
      <%= link_to "Acessar", "#", class: "disciplina-button" %>
    </div>

    <div class="disciplina-card">
      <i class="bi bi-globe"></i>
      <h3>Redes de Computadores</h3>
      <p><strong>Professor:</strong> Letícia Ribeiro</p>
      <p>Princípios, protocolos e arquitetura de redes locais e globais.</p>
      <%= link_to "Acessar", "#", class: "disciplina-button" %>
    </div>

    <div class="disciplina-card">
      <i class="bi bi-database"></i>
      <h3>Banco de Dados</h3>
      <p><strong>Professor:</strong> Ricardo Souza</p>
      <p>Modelagem, normalização e linguagem SQL para sistemas de dados.</p>
      <%= link_to "Acessar", "#", class: "disciplina-button" %>
    </div>

    <div class="disciplina-card">
      <i class="bi bi-terminal"></i>
      <h3>Sistemas Operacionais</h3>
      <p><strong>Professor:</strong> Fernanda Lima</p>
      <p>Gerenciamento de processos, memória e sistemas de arquivos.</p>
      <%= link_to "Acessar", "#", class: "disciplina-button" %>
    </div>

    <div class="disciplina-card">
      <i class="bi bi-lightbulb"></i>
      <h3>Engenharia de Software</h3>
      <p><strong>Professor:</strong> Paulo Gomes</p>
      <p>Conceitos e práticas de análise, projeto e testes de software.</p>
      <%= link_to "Acessar", "#", class: "disciplina-button" %>
    </div>

    <div class="disciplina-card">
      <i class="bi bi-activity"></i>
      <h3>Inteligência Artificial</h3>
      <p><strong>Professor:</strong> Laura Martins</p>
      <p>Conceitos de aprendizado de máquina e resolução automática de problemas.</p>
      <%= link_to "Acessar", "#", class: "disciplina-button" %>
    </div>

    <div class="disciplina-card">
      <i class="bi bi-person-lines-fill"></i>
      <h3>Ética e Sociedade</h3>
      <p><strong>Professor:</strong> Felipe Alves</p>
      <p>Discussões sobre ética profissional e impactos sociais da tecnologia.</p>
      <%= link_to "Acessar", "#", class: "disciplina-button" %>
    </div>
  </div>
</section>